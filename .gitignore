# --- 가상환경 / 파이썬 ---
.venv/
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/

# --- 민감 도면 / 고객 자료 (절대 커밋 금지) ---
# 실제 DWG/DXF 원본은 저장소에 포함하지 않는다. examples/ 안의 합성 샘플만 허용.
*.dwg
*.dxf
!examples/**/*.dxf
real.*

# --- 대용량 중간 산출물 ---
*.json
!package.json
!**/rules/*.json
!**/glossary/*.json
*.svg
real.svg

# --- 생성 결과물 ---
out_*.png
3d_view.png
/build/
/dist/
/output/
.attogrid_cache.json
/sections/
/translations/
/uploads/
drawing.png
drawing.svg
translations.csv
translations.json
attogrid_web.log

# --- OS / 에디터 ---
.DS_Store
.idea/
.vscode/
